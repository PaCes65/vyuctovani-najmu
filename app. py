
import streamlit as st
import pandas as pd
from datetime import datetime
import PyPDF2
import google.generativeai as genai
import json
import re

# --- KONFIGURACE AI ---
if "GEMINI_API_KEY" in st.secrets:
    genai.configure(api_key=st.secrets["GEMINI_API_KEY"])
else:
    st.error("⚠️ V 'Secrets' nebyl nalezen API klíč. Aplikace nebude fungovat.")

# --- PAMĚŤ APLIKACE ---
if "ai_data" not in st.session_state:
    st.session_state.ai_data = {
        "typ_smlouvy": "",
        "poskytovatel": "",
        "platce": "",
        "adresa": "",
        "byt": "",
        "mesicni_najem": 0,
        "mesicni_zaloha": 0
    }

def extrahuj_text_z_pdf(pdf_file):
    """Bezpečné vytažení textu z PDF."""
    try:
        reader = PyPDF2.PdfReader(pdf_file)
        text = ""
        for page in reader.pages:
            content = page.extract_text()
            if content:
                text += content + "\n"
        return text
    except Exception as e:
        return ""

def analyzuj_smlouvu(text_smlouvy):
    """Analýza smlouvy s důrazem na přesnost rolí a částek."""
    prompt = f"""
    Jsi právní analytik. Extrahuj data ze smlouvy do JSON.
    POZOR: Pokud jméno nebo částku v textu jasně nevidíš, vrať prázdnou hodnotu "". Nevymýšlej si!
    
    ROLE:
    1. Pokud jde o NÁJEMNÍ smlouvu: Poskytovatel = Pronajímatel, Plátce = Nájemce.
    2. Pokud jde o PODNÁJEMNÍ smlouvu: Poskytovatel = Nájemce (ten kdo byt pronajímá), Plátce = Podnájemce (obyvatel).
    
    FORMÁT JSON:
    {{
        "typ_smlouvy": "Nájemní smlouva / Podnájemní smlouva",
        "poskytovatel": "přesné jméno",
        "platce": "přesné jméno",
        "adresa": "ulice a město",
        "byt": "číslo",
        "mesicni_najem": pouze_cislo,
        "mesicni_zaloha": pouze_cislo
    }}
    Text: {text_smlouvy}
    """
    try:
        model = genai.GenerativeModel('gemini-1.5-flash')
        res = model.generate_content(prompt)
        # Očištění JSONu od markdownu
        match = re.search(r'\{.*\}', res.text, re.DOTALL)
        if match:
            return json.loads(match.group())
        return st.session_state.ai_data
    except:
        return st.session_state.ai_data

def analyzuj_vyuctovani_svj(text_vyuctovani):
    """Audit vyúčtování SVJ - položkový rozpis."""
    prompt = f"""
    Jsi auditor. Vypiš VŠECHNY položky z vyúčtování SVJ do JSONu.
    Urči, zda je položka 'preuctovatelne' na nájemce (true = služby jako voda, teplo, odpad) 
    nebo zůstává za majitelem (false = fond oprav, pojištění, správa).
    
    JSON:
    {{
        "polozky": [
            {{"nazev": "...", "castka": 123, "preuctovatelne": true, "duvod": "..."}}
        ]
    }}
    Text: {text_vyuctovani}
    """
    try:
        model = genai.GenerativeModel('gemini-1.5-flash')
        res = model.generate_content(prompt)
        match = re.search(r'\{.*\}', res.text, re.DOTALL)
        if match:
            return json.loads(match.group())
        return {"polozky": []}
    except:
        return {"polozky": []}

# --- UI ---
st.set_page_config(page_title="Vyúčtování PRO", layout="centered")
st.title("🏢 Profesionální vyúčtování služeb")

# 1. SMLOUVA
st.header("1. Smlouva")
soubor_sml = st.file_uploader("Vložte smlouvu (PDF)", type="pdf")
if soubor_sml and st.button("✨ Analyzovat smlouvu", use_container_width=True):
    with st.spinner("Právní analýza dokumentu..."):
        text = extrahuj_text_z_pdf(soubor_sml)
        data = analyzuj_smlouvu(text)
        st.session_state.ai_data.update(data)
        st.success(f"Detekována: {st.session_state.ai_data['typ_smlouvy']}")

# 2. KONTROLA
st.header("2. Kontrola údajů")
col1, col2 = st.columns(2)
with col1:
    v_poskytovatel = st.text_input("Poskytovatel (příjemce)", value=st.session_state.ai_data["poskytovatel"])
    v_platce = st.text_input("Plátce (obyvatel)", value=st.session_state.ai_data["platce"])
with col2:
    v_adresa = st.text_input("Adresa nemovitosti", value=st.session_state.ai_data["adresa"])
    v_byt = st.text_input("Byt č.", value=st.session_state.ai_data["byt"])

c3, c4 = st.columns(2)
with c3:
    v_najem = st.number_input("Měsíční nájemné (Kč)", value=int(st.session_state.ai_data["mesicni_najem"]))
with c4:
    v_zaloha = st.number_input("Předepsaná záloha (Kč)", value=int(st.session_state.ai_data["mesicni_zaloha"]))

# 3. PODKLADY
st.header("3. Podklady")
soubor_svj = st.file_uploader("Vyúčtování SVJ (PDF)", type="pdf")
soubor_banka = st.file_uploader("Výpis plateb (Excel/CSV)", type=["xlsx", "csv"])

st.subheader("Ostatní úpravy")
v_bonus = st.number_input("Bonus/Přeplatek z loňska (Kč)", value=0, help="Částka, kterou si nájemník odečetl kvůli loňskému přeplatku.")

# VÝPOČET
if st.button("🚀 Vygenerovat normované vyúčtování", use_container_width=True):
    if not soubor_svj or not soubor_banka:
        st.error("Chybí podklady pro výpočet.")
    else:
        with st.spinner("Generování reportu..."):
            try:
                # Banka
                df = pd.read_csv(soubor_banka) if soubor_banka.name.endswith('.csv') else pd.read_excel(soubor_banka)
                total_banka = df['Castka'].sum()
                mesice = len(df)
                smluvni_najem_celkem = v_najem * mesice
                uhrazene_zalohy = total_banka - smluvni_najem_celkem + v_bonus

                # SVJ
                text_svj = extrahuj_text_z_pdf(soubor_svj)
                audit = analyzuj_vyuctovani_svj(text_svj)
                polozky = audit.get("polozky", [])
                uznatelne = sum(p['castka'] for p in polozky if p.get('preuctovatelne'))

                # REPORT
                st.divider()
                st.header("📄 PROTOKOL O VYÚČTOVÁNÍ")
                
                st.subheader("I. Základní informace")
                st.write(f"**Typ vztahu:** {st.session_state.ai_data['typ_smlouvy']}")
                st.write(f"**Nemovitost:** {v_adresa}, Byt: {v_byt}")
                st.write(f"**Poskytovatel:** {v_poskytovatel}")
                st.write(f"**Plátce:** {v_platce}")

                st.subheader("II. Položkový rozpis nákladů (Audit SVJ)")
                if polozky:
                    pdf_table = pd.DataFrame(polozky)
                    pdf_table['Odpovědnost'] = pdf_table['preuctovatelne'].map({True: "🟢 Plátce", False: "🔴 Vlastník"})
                    st.table(pdf_table[['nazev', 'castka', 'Odpovědnost', 'duvod']])
                
                st.subheader("III. Finanční bilance a postup")
                st.markdown(f"""
                **1. Příjmy (Bankovní výpis):**
                - Celková suma plateb na účet ({mesice} měsíců): **{total_banka:,.2f} Kč**
                - Odpočet smluvního nájemného: **- {smluvni_najem_celkem:,.2f} Kč**
                - Připočtení bonusu (loňský přeplatek): **+ {v_bonus:,.2f} Kč**
                - **Suma uhrazených záloh: {uhrazene_zalohy:,.2f} Kč**
                
                **2. Náklady (Audit vyúčtování):**
                - Skutečné uznatelné náklady na služby: **{uznatelne:,.2f} Kč**
                
                **3. Výsledek:**
                - Rozdíl (Zálohy - Náklady): **{(uhrazene_zalohy - uznatelne):,.2f} Kč**
                """)

                rozdil = uhrazene_zalohy - uznatelne
                if rozdil >= 0:
                    st.success(f"**VÝSLEDEK: Přeplatek ve výši {rozdil:,.2f} Kč**")
                    st.write("Částka bude vrácena plátci nebo započtena do příští platby.")
                else:
                    st.error(f"**VÝSLEDEK: Nedoplatek ve výši {abs(rozdil):,.2f} Kč**")
                    st.write("Plátce je povinen uhradit tuto částku v zákonné lhůtě.")

            except Exception as e:
                st.error(f"Chyba při zpracování: {e}")
